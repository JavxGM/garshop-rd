# Supabase — mismo proyecto que GainRD
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Service role key de Supabase (solo en servidor — NUNCA expongas este valor al cliente)
# Se usa en /api/pedidos para guardar pedidos con privilegios de admin.
# Puedes omitirla y usar solo el anon key si las RLS lo permiten,
# pero la service role es más segura para operaciones de escritura desde el servidor.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Número de WhatsApp para recibir pedidos (sin + ni espacios)
NEXT_PUBLIC_GARSHOP_WHATSAPP_NUMBER=18091234567

# Contraseña simple para acceder al panel admin
NEXT_PUBLIC_ADMIN_PASSWORD=garshop2024

# ─── Bot de Telegram para notificaciones de pedidos ────────────────────────
# Deja vacías estas variables si no quieres notificaciones por Telegram.
# El bot notifica automáticamente cuando un cliente envía un pedido nuevo.
#
# Cómo obtener el token: habla con @BotFather en Telegram → /newbot
# Cómo obtener el chat ID: envía un mensaje al bot y visita:
#   https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#   Busca "chat":{"id": <ESTE_NÚMERO>}
GARSHOP_TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
GARSHOP_TELEGRAM_CHAT_ID=987654321

# ─── Pipeline de procesamiento de imágenes ─────────────────────────────────
# remove.bg: quita el fondo de las fotos de productos automáticamente.
# Plan gratuito: 50 imágenes/mes. Obtén tu API key en https://www.remove.bg/dashboard
REMOVEBG_API_KEY=your_removebg_api_key

# Gmail: envía alertas por email cuando se acerque el límite mensual de remove.bg.
# Usar las mismas credenciales de Finanzas Javier (ya configuradas en Vercel).
GMAIL_USER=tucorreo@gmail.com
GMAIL_APP_PASSWORD=tu_app_password
